<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #D0E6FF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.controller.ClientController">
   <children>
      <Label layoutX="120.0" layoutY="137.0" text="Add a new client">
         <font>
            <Font size="33.0" />
         </font></Label>
      <TextField fx:id="nipField" layoutX="80.0" layoutY="220.0" />
      <TextField fx:id="companyNameField" layoutX="242.0" layoutY="220.0" />
      <TextField fx:id="addressField" layoutX="80.0" layoutY="288.0" />
      <TextField fx:id="phoneField" layoutX="242.0" layoutY="288.0" />
      <TextField fx:id="emailField" layoutX="80.0" layoutY="359.0" />
      <Label layoutX="80.0" layoutY="190.0" text="NIP:">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="242.0" layoutY="190.0" text="Company name:">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="80.0" layoutY="258.0" text="Address:">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="242.0" layoutY="258.0" text="Phone number:">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Label layoutX="80.0" layoutY="329.0" text="Email:">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <Button fx:id="createClientButton" layoutX="198.0" layoutY="398.0" mnemonicParsing="false" onAction="#handleCreateClient" text="Create">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
      <Button fx:id="cancelButton" layoutX="463.0" layoutY="697.0" mnemonicParsing="false" onAction="#handleCancel" text="Cancel">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
      <Label layoutX="691.0" layoutY="137.0" text="Current clients">
         <font>
            <Font size="33.0" />
         </font>
      </Label>
      <TableView fx:id="clientsTable" layoutX="659.0" layoutY="194.0" prefHeight="408.0" prefWidth="276.0">
        <columns>
          <TableColumn fx:id="nipColumn" prefWidth="75.0" text="NIP" />
          <TableColumn fx:id="companyColumn" prefWidth="104.0" text="Company name" />
            <TableColumn fx:id="phoneColumn" prefWidth="96.0" text="Phone number" />
        </columns>
      </TableView>
      <Button fx:id="continueButton" layoutX="682.0" layoutY="613.0" mnemonicParsing="false" onAction="#handleContinue" text="Select and continue">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
   </children>
</AnchorPane>

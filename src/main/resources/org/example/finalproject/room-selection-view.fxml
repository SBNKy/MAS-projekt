<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #D0E6FF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finalproject.controller.ReservationController">
   <children>
      <Label fx:id="currentClientLabel" layoutX="374.0" layoutY="34.0" text="Current client: ">
         <font>
            <Font size="28.0" />
         </font>
      </Label>
      <Label layoutX="117.0" layoutY="169.0" text="Filter by dates">
         <font>
            <Font size="26.0" />
         </font>
      </Label>
      <Label layoutX="103.0" layoutY="224.0" text="From:">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <Label layoutX="256.0" layoutY="224.0" text="To:">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <DatePicker fx:id="dateFromPicker" layoutX="51.0" layoutY="245.0" prefHeight="25.0" prefWidth="139.0" />
      <DatePicker fx:id="dateToPicker" layoutX="197.0" layoutY="245.0" prefHeight="25.0" prefWidth="139.0" />
      <Button fx:id="filterButton" layoutX="158.0" layoutY="283.0" mnemonicParsing="false" onAction="#handleFilter" text="Filter">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Label layoutX="374.0" layoutY="133.0" text="Available hotel objects">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <Label layoutX="752.0" layoutY="133.0" text="Available rooms">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <TableView fx:id="hotelsTable" layoutX="343.0" layoutY="169.0" prefHeight="314.0" prefWidth="292.0">
        <columns>
          <TableColumn fx:id="hotelNameColumn" prefWidth="94.0" text="Name" />
          <TableColumn fx:id="hotelAddressColumn" prefWidth="156.0" text="Address" />
            <TableColumn fx:id="hotelStarsColumn" prefWidth="41.0" text="Stars" />
        </columns>
      </TableView>
      <TableView fx:id="roomsTable" editable="true" layoutX="667.0" layoutY="169.0" prefHeight="314.0" prefWidth="334.0">
        <columns>
          <TableColumn fx:id="roomSelectColumn" prefWidth="26.0" text="[X]" />
          <TableColumn fx:id="roomTypeColumn" prefWidth="77.0" text="Type" />
            <TableColumn fx:id="roomFloorColumn" prefWidth="37.0" text="Floor" />
            <TableColumn fx:id="roomStandardColumn" prefWidth="88.0" text="Standard" />
            <TableColumn fx:id="roomAreaColumn" prefWidth="33.0" text="Area" />
            <TableColumn fx:id="roomPriceColumn" prefWidth="72.0" text="Price" />
        </columns>
      </TableView>
      <Button fx:id="additionalServicesButton" layoutX="522.0" layoutY="505.0" mnemonicParsing="false" onAction="#handleAdditionalServices" text="Configure additional services">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="cancelButton" layoutX="391.0" layoutY="692.0" mnemonicParsing="false" onAction="#handleCancel" text="Cancel">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
      <Button fx:id="continueButton" layoutX="542.0" layoutY="692.0" mnemonicParsing="false" onAction="#handleContinue" text="Continue">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
